#ifndef CONFIG_H
#define CONFIG_H

// ============================================
// WiFi Configuration
// ============================================
// IMPORTANT: Update these with your WiFi credentials
#define WIFI_SSID "YourWiFiSSID"
#define WIFI_PASSWORD "YourWiFiPassword"

// ============================================
// Web Server Configuration
// ============================================
#define WEB_SERVER_PORT 80

// ============================================
// Hardware Pin Configuration for ESP32-S3
// ============================================
// Relay/Solenoid Control Pins
// These pins control the relays that activate solenoid valves
// Adjust based on your wiring setup
#define ZONE1_PIN 1
#define ZONE2_PIN 2
#define ZONE3_PIN 3
#define ZONE4_PIN 4

// Number of watering zones
// Adjust if you have fewer zones (1-4)
#define NUM_ZONES 4

// ============================================
// Safety and Timing Configuration
// ============================================
// Safety timeout (milliseconds) - maximum watering duration per zone
// This prevents valves from staying open indefinitely if something goes wrong
#define MAX_WATERING_DURATION 3600000  // 1 hour (60 * 60 * 1000)

// Default watering duration (milliseconds) when no duration is specified
#define DEFAULT_WATERING_DURATION 600000  // 10 minutes (10 * 60 * 1000)

// ============================================
// Storage Configuration
// ============================================
// NVS (Non-Volatile Storage) namespace for storing configuration
// This is used to save schedules and settings
#define NVS_NAMESPACE "watering"

// ============================================
// Advanced Configuration (Optional)
// ============================================
// Uncomment and adjust if needed:

// Time zone offset in seconds (for NTP time synchronization)
// Default is UTC (0). Examples:
// #define GMT_OFFSET_SEC -28800    // PST (UTC-8)
// #define GMT_OFFSET_SEC -18000    // EST (UTC-5)
// #define GMT_OFFSET_SEC 3600      // CET (UTC+1)

// Daylight saving time offset in seconds
// #define DAYLIGHT_OFFSET_SEC 3600  // 1 hour

// NTP server (for time synchronization)
// #define NTP_SERVER "pool.ntp.org"
// Alternative NTP servers:
// #define NTP_SERVER "time.nist.gov"
// #define NTP_SERVER "time.google.com"

// Relay logic (uncomment if your relays are active LOW)
// #define RELAY_ACTIVE_LOW

#endif
